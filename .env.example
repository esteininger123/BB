# BB-Kalkulator V2 — Environment-Variablen (Vorlage, KEINE Werte)
#
# Schnellster Weg, die echten Werte lokal zu bekommen (du bist Vercel-Member):
#   npx vercel link            # Projekt "bb" im Team waehlen
#   npx vercel env pull .env.local
# Damit hat .env.local alle Werte aus Vercel — du musst nichts manuell eintragen.
#
# Diese Datei ist nur die REFERENZ, welche Variablen es gibt (25). Quelle der
# Wahrheit ist Vercel. Tabellen-IDs leben im Code (api/_lib/tables.js).

# --- Auth / Session ---
GOOGLE_CLIENT_ID=          # Login-OAuth Client-ID (oeffentlich, kein Secret)
JWT_SECRET=                # signiert das bbk_session-Cookie (Secret)
ADMIN_EMAILS=              # Komma-Liste der Admin-Mails (Edgar, Henry)
ALLOWED_ORIGINS=           # erlaubte CORS-Origins, z.B. https://backstube.bub-immo.de

# --- Airtable ---
AIRTABLE_TOKEN=            # Personal Access Token (Secret)
AIRTABLE_BASE_ID=          # appikHUetNyeonXBX (Objektmanagement)
PROJEKT_TABLE_ID=          # optional — Override, Default in tables.js
PROJEKT_HEAD_TABLE_ID=     # optional — Override
WOHNEINHEIT_TABLE_ID=      # optional — Override
WOHNEINHEIT_OBJEKT_FILTER= # WE-Filter-Konfiguration

# --- Google Drive (Upload-Ordner) ---
GOOGLE_OAUTH_CLIENT_ID=        # Drive-OAuth Client-ID (oeffentlich)
GOOGLE_OAUTH_CLIENT_SECRET=    # Drive-OAuth Secret
GOOGLE_OAUTH_REFRESH_TOKEN=    # via scripts/get-drive-token.js holen (Login info@bub-immo.de)
DRIVE_ROOT_FOLDER_ID=          # Ziel-Ordner-ID

# --- PandaDoc (E-Signatur Selbstauskunft / Reservierung) ---
PANDADOC_API_KEY=                    # Secret
PANDADOC_WEBHOOK_SECRET=             # HMAC-Validierung (muss zur Webhook-Config passen)
PANDADOC_TEMPLATE_ID_RESERVIERUNG=   # Template-ID
PANDADOC_EDITOR_HOST=                # Editor-Host

# --- HubSpot (Kontaktsuche im Neuer-Kunde-Modal) ---
HUBSPOT_TOKEN=             # Private-App-Token (Secret)
HUBSPOT_API_BASE=          # API-Base-URL

# --- Anthropic (Assistent in api/assistent.js) ---
ANTHROPIC_API_KEY=         # Secret — eigener B&B-Key empfohlen

# --- PDF / Serverless Chromium ---
CHROMIUM_PACK_URL=         # URL zum @sparticuz/chromium-Pack

# --- Cron / Upload-Portal ---
CRON_SECRET=               # schuetzt die Cron-Route (Secret)
UPLOAD_TOKEN_SECRET=       # signiert Kunden-Upload-Portal-Links (Secret — NICHT neu generieren, wenn aktive Links draussen sind)
RESERV_FRIST_TAGE=         # Reservierungsfrist in Tagen (Zahl)
