{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "cleanUrls": true,
  "functions": {
    "api/sa/send-for-signature.js": {
      "memory": 3008,
      "maxDuration": 60
    },
    "api/spike/html-to-pdf.js": {
      "memory": 3008,
      "maxDuration": 60
    },
    "api/reservierung/send-for-signature.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/kunden/[id].js": {
      "maxDuration": 30
    },
    "api/stammdaten/refresh-all.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/pandadoc/webhook.js": {
      "maxDuration": 30
    },
    "api/assistent.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/stammdaten/refresh-all",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/stammdaten/refresh-all",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/stammdaten/refresh-all",
      "schedule": "0 16 * * *"
    }
  ]
}
